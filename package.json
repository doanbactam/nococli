{
  "name": "nococli",
  "version": "1.1.0",
  "description": "Keep your code yours — remove AI co-author signatures from git commits",
  "type": "module",
  "bin": {
    "noco": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --outdir ./dist --target node && node -e \"const fs=require('fs'); const p='./dist/cli.js'; const c=fs.readFileSync(p,'utf8'); fs.writeFileSync(p,'#!/usr/bin/env node\\n'+c)\"",
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "test:e2e": "node ./scripts/e2e-install.mjs",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "keywords": [
    "git",
    "hook",
    "ai",
    "claude",
    "copilot",
    "commit",
    "cursor",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/doanbactam/noco"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.11.0",
    "bun-types": "^1.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ]
}
