{
  "name": "@iamsyr/noco",
  "version": "1.0.0",
  "description": "Keep your code yours — remove AI co-author signatures from git commits",
  "type": "module",
  "main": "./dist/install.js",
  "bin": {
    "noco": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build ./src/*.ts --outdir ./dist --target bun && bun build ./src/*.ts --outdir ./dist --target node",
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "git",
    "hook",
    "ai",
    "claude",
    "copilot",
    "commit",
    "cursor",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/git-no-ai-author"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.1",
    "prompts": "^2.4.2",
    "listr2": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/prompts": "^2.4.9",
    "bun-types": "^1.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "hooks"
  ]
}
