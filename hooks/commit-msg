#!/bin/bash
# git-no-ai-author: Remove AI co-author signatures from commit messages
# Installed by npx git-no-ai-author

COMMIT_MSG_FILE=$1

# Remove AI co-author signatures using extended regex
# Pattern matches: Co-Authored-By: <AI-Name> <version> <email> ...
# Uses character classes for case-insensitive matching (portable across sed implementations)
sed -i -E '/^[Cc][Oo]-[Aa][Uu][Tt][Hh][Oo][Rr][Ee][Dd]-[Bb][Yy]: (Claude|GitHub Copilot|ChatGPT|Anthropic|OpenAI|Cursor AI|AI Assistant|Tabnine|CodeWhisperer|Codeium|Replit Ghostwriter|Sourcegraph Cody|Cody).*/d' "$COMMIT_MSG_FILE"

# Remove trailing empty lines
sed -i -e :a -e '/^[[:space:]]*$/{$d;N;ba' -e '}' "$COMMIT_MSG_FILE"
